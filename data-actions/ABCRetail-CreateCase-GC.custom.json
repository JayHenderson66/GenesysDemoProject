{
  "name": "ABC Retail - Create Case",
  "integrationType": "purecloud-data-actions",
  "actionType": "custom",
  "config": {
    "request": {
      "requestUrlTemplate": "/api/v2/casemanagement/cases",
      "requestType": "POST",
      "headers": {},
      "requestTemplate": "#if($input.workItemType == \"delivery_delay\")\n  #set($casePlanId = \"26711806-9002-474d-926d-bc2d38a12196\")\n#elseif($input.workItemType == \"shipment_exception\")\n  #set($casePlanId = \"4adc4d54-597e-415f-9aad-ec764684baa2\")\n#elseif($input.workItemType == \"refund_request\")\n  #set($casePlanId = \"be556187-8de5-45a9-a2ae-a66e242c296e\")\n#elseif($input.workItemType == \"credit_hold\")\n  #set($casePlanId = \"e1246b01-dcc6-4fb8-a97b-8dfbdf07178f\")\n#end\n{\n  \"caseplanId\": \"$casePlanId\",\n#if($input.externalContactId && $input.externalContactId.length() > 30)\n  \"externalContactId\": \"${input.externalContactId}\",\n#end\n  \"subject\": \"${input.subject}\",\n  \"description\": \"${input.description}\",\n  \"customAttributes\": {\n    \"customer_id_identifier\": \"${input.customerId}\",\n    \"order_number_text\": \"${input.orderNumber}\",\n    \"intent_text\": \"${input.workItemType}\",\n    \"case_type_text\": \"${input.workItemType}\",\n    \"channel_text\": \"web_messaging\"\n  }\n}"
    },
    "response": {
      "translationMap": {
        "caseId": "$.id",
        "caseReference": "$.reference"
      },
      "translationMapDefaults": {
        "caseReference": "\"unknown\""
      },
      "successTemplate": "{\"caseId\": ${caseId}, \"caseReference\": ${caseReference}}"
    }
  },
  "contract": {
    "input": {
      "inputSchema": {
        "type": "object",
        "required": [
          "workItemType",
          "subject",
          "description"
        ],
        "properties": {
          "workItemType": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "orderNumber": {
            "type": "string"
          },
          "customerId": {
            "type": "string"
          },
          "externalContactId": {
            "type": "string"
          }
        }
      }
    },
    "output": {
      "successSchema": {
        "type": "object",
        "properties": {
          "caseId": {
            "type": "string"
          },
          "caseReference": {
            "type": "string"
          }
        }
      }
    }
  },
  "secure": false
}
