{
  "name": "ABC Retail - Set WI Status - In Progress",
  "integrationType": "purecloud-data-actions",
  "actionType": "custom",
  "config": {
    "request": {
      "requestUrlTemplate": "/api/v2/taskmanagement/workitems/${input.workitemId}",
      "requestType": "PATCH",
      "headers": {
        "Content-Type": "application/json"
      },
      "requestTemplate": "{\"statusId\": \"9d5c8d2e-5b3a-4177-8fa2-da19fc018ab7\"}"
    },
    "response": {
      "translationMap": {
        "workitemId": "$.id",
        "statusId": "$.statusId"
      },
      "translationMapDefaults": {},
      "successTemplate": "{\"workitemId\": ${workitemId}, \"statusId\": ${statusId}}"
    }
  },
  "contract": {
    "input": {
      "inputSchema": {
        "type": "object",
        "properties": {
          "workitemId": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "output": {
      "successSchema": {
        "type": "object",
        "properties": {
          "workitemId": { "type": "string" },
          "statusId": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "secure": false
}
